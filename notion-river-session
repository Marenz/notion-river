#!/bin/sh
# Notion River session launcher for display managers (lightdm, etc).
# Installed to /usr/bin/ by the package.

# Default XKB layout — users should override in ~/.config/river/init
export XKB_DEFAULT_LAYOUT="${XKB_DEFAULT_LAYOUT:-us}"
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=river
export MOZ_ENABLE_WAYLAND=1
export ELECTRON_OZONE_PLATFORM_HINT=wayland

# Use user's init script if it exists, otherwise run notion-river directly
if [ -x "$HOME/.config/river/init" ]; then
    exec river -c "$HOME/.config/river/init"
elif [ -f "$HOME/.config/river/init" ]; then
    exec river -c "sh $HOME/.config/river/init"
else
    exec river -c notion-river
fi
