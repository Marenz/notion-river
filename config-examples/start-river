#!/bin/sh
# Launch River with notion-river WM.

# Two layouts: de/neo (default) and plain de. Ctrl+F12 toggles.
export XKB_DEFAULT_LAYOUT=de,de
export XKB_DEFAULT_VARIANT=neo,
export XKB_DEFAULT_MODEL=pc105
export XKB_DEFAULT_OPTIONS=grp:ctrl_f12_toggle
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=river
export MOZ_ENABLE_WAYLAND=1
export ELECTRON_OZONE_PLATFORM_HINT=wayland
export RUST_LOG=info

exec river -c ~/.config/river/init
