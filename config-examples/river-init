#!/bin/sh
# River 0.4.x init script — launched via: river -c ~/.config/river/init
# This runs as a child of River, so WAYLAND_DISPLAY is set.

# ── Environment ──
export XDG_CURRENT_DESKTOP=river
export MOZ_ENABLE_WAYLAND=1
export ELECTRON_OZONE_PLATFORM_HINT=wayland
export ELECTRON_ENABLE_WAYLAND=1
export RUST_LOG=info

# ── Import env into systemd so portals (file dialogs etc.) work ──
systemctl --user import-environment WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP

# ── Install example configs on first run ──
EXAMPLES="/usr/share/notion-river/examples"
if [ -d "$EXAMPLES/waybar" ] && [ ! -f "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/config.jsonc" ]; then
    mkdir -p "${XDG_CONFIG_HOME:-$HOME/.config}/waybar"
    cp "$EXAMPLES/waybar/"* "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/"
    echo "Installed waybar config from $EXAMPLES/waybar/"
fi
if [ -f "$EXAMPLES/config.toml" ] && [ ! -f "${XDG_CONFIG_HOME:-$HOME/.config}/notion-river/config.toml" ]; then
    mkdir -p "${XDG_CONFIG_HOME:-$HOME/.config}/notion-river"
    cp "$EXAMPLES/config.toml" "${XDG_CONFIG_HOME:-$HOME/.config}/notion-river/config.toml"
    echo "Installed notion-river config from $EXAMPLES/config.toml"
fi
if [ ! -f "${XDG_CONFIG_HOME:-$HOME/.config}/river/autostart" ] && [ -f "$EXAMPLES/autostart" ]; then
    cp "$EXAMPLES/autostart" "${XDG_CONFIG_HOME:-$HOME/.config}/river/autostart"
    echo "Installed river autostart from $EXAMPLES/autostart"
fi
if [ ! -f "${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/kanshi.service" ] && [ -f "$EXAMPLES/kanshi.service" ]; then
    mkdir -p "${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
    cp "$EXAMPLES/kanshi.service" "${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/kanshi.service"
    echo "Installed kanshi user service from $EXAMPLES/kanshi.service"
fi

if [ -f "${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/kanshi.service" ]; then
    systemctl --user daemon-reload
    systemctl --user is-enabled kanshi.service >/dev/null 2>&1 || \
        systemctl --user enable kanshi.service >/dev/null 2>&1
    systemctl --user is-active kanshi.service >/dev/null 2>&1 || \
        systemctl --user start kanshi.service >/dev/null 2>&1
fi

# ── Source user-specific autostart (keyboard layout, apps, etc.) ──
AUTOSTART="${XDG_CONFIG_HOME:-$HOME/.config}/river/autostart"
if [ -f "$AUTOSTART" ]; then
    . "$AUTOSTART"
fi

# ── Start the window manager ──
# Always restart unless killed with SIGKILL (-9).
while true; do
    notion-river
    echo "notion-river exited ($?), restarting..."
    sleep 0.5
done
